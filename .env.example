# ════════════════════════════════════════════════════════════════
# QMS — .env.example
# Copy file này thành `.env` rồi điền giá trị thật. File `.env` đã
# gitignore — KHÔNG commit credentials thật.
# ════════════════════════════════════════════════════════════════

# ─── Backend (Docker compose) ─────────────────────────────────────
QMS_DB_CONN=Server=host.docker.internal,1433;Database=QMS_DA;User Id=qms_app;Password=YOUR_PASSWORD;TrustServerCertificate=True;
JWT_SECRET=GENERATE_RANDOM_64_CHARS_HERE_FOR_HMAC_SHA256_JWT_SIGNING

# ─── ai-face (Hikvision camera) ───────────────────────────────────
# Khi không có camera Hikvision → đặt HIK_CAMERA_ENABLED=false để chỉ dùng webcam USB.
HIK_CAMERA_IP=192.168.1.6
HIK_CAMERA_USER=admin
HIK_CAMERA_PASSWORD=YOUR_HIKVISION_PASSWORD
HIK_CAMERA_STREAM=2
HIK_CAMERA_ENABLED=true

# ─── Viettel TTS (optional) ───────────────────────────────────────
# Đăng ký tại https://viettelai.vn/ để lấy token.
# Để trống → backend không gọi Viettel, FE fallback browser speechSynthesis.
VIETTEL_TTS_TOKEN=

# ─── DB clone pipeline (chỉ dev khi clone từ DB cũ về local) ─────
# Khi reproduce data từ DB công ty (chạy database/setup/_scripts/clone_data.py).
# Bỏ qua nếu chỉ dùng QMS_DA local có sẵn.
SRC_DB_SERVER=
SRC_DB_USER=
SRC_DB_PASS=

# ─── Face encryption ──────────────────────────────────────────────
# 64-char hex (32 bytes) cho AES-256-GCM. Để trống = key tạm trong RAM
# (mất khi restart, BN enroll cũ identify không được).
FACE_ENCRYPTION_KEY=
