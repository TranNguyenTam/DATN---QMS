# Frontend API base URL (include /api/v1 suffix)
# Local dev default can be omitted because Vite proxy is configured.
# Example for cross-origin backend:
# VITE_API_URL=http://localhost:8080/api/v1

# Frontend WebSocket endpoint for STOMP
# Local dev default can be omitted because Vite proxy is configured.
# Example for cross-origin backend:
# VITE_WS_URL=ws://localhost:8080/ws

# Public URL nhúng vào QR code Kiosk (BN quét bằng điện thoại theo dõi STT).
# Nếu để trống: dùng window.location.origin = URL trình duyệt mở Kiosk.
# Mở Kiosk bằng localhost → QR chứa localhost → iPhone KHÔNG vào được.
# Demo LAN: mở Kiosk bằng IP LAN của PC (http://192.168.x.x:5173) hoặc set ở đây.
# VITE_PUBLIC_URL=http://192.168.1.50:5173
